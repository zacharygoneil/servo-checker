# Google Maps Platform API key
# Enable: Maps JavaScript API, Directions API, Places API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Service Victoria Servo Saver Public API — Consumer ID
# Apply at: https://service.vic.gov.au/find-services/transport-and-driving/servo-saver/help-centre/servo-saver-public-api
VITE_SERVO_SAVER_API_KEY=your_servo_saver_consumer_id_here
